# AIPiloty Configuration
APP_NAME=AIPiloty
APP_ENV=development
DEBUG=true

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite+aiosqlite:///./aipiloty.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/aipiloty

# Auth
API_KEY=aipiloty-dev-key-change-in-production
JWT_SECRET=change-this-to-a-random-secret-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-coder-v2:16b
OLLAMA_CONTEXT_LENGTH=8192
OLLAMA_TEMPERATURE=0.3

# Encryption
ENCRYPTION_KEY=

# Image Generation (optional)
IMAGE_GEN_API_URL=

# Workspace
WORKSPACE_ROOT=

# fetch_url tool: set false only on dev machines with broken Python SSL certs (not for production)
FETCH_URL_VERIFY_SSL=true

# Native RAG (Qdrant + Ollama embeddings)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=aipiloty_kb
EMBEDDING_MODEL=nomic-embed-text
# Comma-separated absolute paths that are allowed for KB ingestion
KB_ALLOWED_ROOTS=
KB_CHUNK_SIZE=512
KB_CHUNK_OVERLAP=64

# Image generation — add API keys in Settings → Image Providers (encrypted DB).
# Do NOT put OpenAI/Gemini API keys here. ENCRYPTION_KEY is the master key only.
# Optional boot fallbacks:
# IMAGE_GEN_API_URL=http://127.0.0.1:8188
# IMAGE_PROVIDER=sdxl_turbo
# Phase C — optional cloud LLM for hard GENERAL_QA only (tools stay on Ollama)
# CLOUD_LLM_ENABLED=true
# CLOUD_LLM_MODEL=gpt-4o-mini
# CLOUD_LLM_FOR=complex_qa
# SEMANTIC_ROUTER_ENABLED=true
